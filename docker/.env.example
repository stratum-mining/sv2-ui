# ============================================================
# SV2 Miner Stack — Environment Configuration
# ============================================================
# Copy this file to .env and edit the values.
#
# Two modes are supported:
#
#   tProxy-only  — tProxy connects directly to an SV2 pool.
#                  Run: docker compose up sv2_ui tproxy
#
#   JD mode      — JDC constructs block templates, tProxy connects to JDC.
#                  Requires a Bitcoin Core node with IPC enabled.
#                  Run: docker compose up
# ============================================================

# --- Translator Proxy (tProxy) --------------------------------

TPROXY_USER_IDENTITY=your_username_here

# Upstream connection — where tProxy connects to.
#
# tProxy-only mode: point at your SV2 pool
#   TPROXY_UPSTREAM_ADDRESS=75.119.150.111
#   TPROXY_UPSTREAM_PORT=34254
#
# JD mode: point at the jd_client container
#   TPROXY_UPSTREAM_ADDRESS=jd_client
#   TPROXY_UPSTREAM_PORT=34265
TPROXY_UPSTREAM_ADDRESS=75.119.150.111
TPROXY_UPSTREAM_PORT=34254
TPROXY_UPSTREAM_AUTHORITY_PUBKEY=3VANfft6ei6jQFBnHMcRVCZHEMkuGRYMpxjc3AYEPjQrmtF96a

# Channel aggregation: true = all miners share one upstream channel
TPROXY_AGGREGATE_CHANNELS=true

# Difficulty / VarDiff
TPROXY_MIN_INDIVIDUAL_MINER_HASHRATE=10_000_000_000_000.0
TPROXY_SHARES_PER_MINUTE=6.0
# Set to false when using JD mode (JDC handles vardiff)
TPROXY_ENABLE_VARDIFF=true


# --- JD Client (only needed in JD mode) ----------------------

JDC_USER_IDENTITY=your_username_here
JDC_SHARES_PER_MINUTE=6.0
JDC_SHARE_BATCH_SIZE=10
JDC_SIGNATURE=Sv2MinerSignature
JDC_COINBASE_REWARD_SCRIPT=addr(tb1qr8xjkrx46yfsch7q2ts2g007haufq48n9pe6qc)

# Template construction
JDC_BITCOIN_NETWORK=mainnet
JDC_FEE_THRESHOLD=100
JDC_MIN_INTERVAL=5

# Pool + JDS upstream connection
JDC_UPSTREAM_AUTHORITY_PUBKEY=3VANfft6ei6jQFBnHMcRVCZHEMkuGRYMpxjc3AYEPjQrmtF96a
JDC_POOL_ADDRESS=75.119.150.111
JDC_POOL_PORT=34254
JDC_UPSTREAM_JDS_ADDRESS=75.119.150.111
JDC_UPSTREAM_JDS_PORT=34264

# Bitcoin Core IPC socket path on the HOST machine.
# On Umbrel/Start9, this is typically exposed by the Bitcoin Core app.
# Example: /path/to/.bitcoin/node.sock
BITCOIN_SOCKET_PATH=/path/to/your/node.sock
